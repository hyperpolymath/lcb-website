# RSR-compliant .gitignore
# SPDX-License-Identifier: PMPL-1.0-or-later

# ── Build artifacts ──────────────────────────────────────
build/
dist/
target/
*.o
*.ali

# ── Cabal cache ──────────────────────────────────────────
/.cabal

# ── Cerro Torre / supply-chain ───────────────────────────
.ct-cache/
in_toto/
sbom/
*.ctp.signed

# ── Database backups ─────────────────────────────────────
*.sql
*.sql.gz

# ── Environment / secrets ────────────────────────────────
.env
.env.local
.env.*.local
.env.production-reference
*.crt
*.key
*.pem

# SOPS+age: block all plaintext, allow only ciphertext files.
secrets/*
!secrets/README.md
!secrets/*.enc.yaml
!secrets/*.enc.yml
!secrets/*.enc.json
!secrets/*.enc.toml
!secrets/*.enc.env
# Belt-and-braces: any file with .plain. in its name is NEVER committable.
*.plain.yaml
*.plain.yml
*.plain.json
*.plain.toml
*.plain.env
# Decrypted outputs (if user redirects `sops -d` to a file by accident)
*.decrypted.*

# ── IDE / editor ─────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── Node / Deno (safeguard) ──────────────────────────────
node_modules/

# ── OS ───────────────────────────────────────────────────
.DS_Store
.directory
Thumbs.db

# ── PHP tooling ──────────────────────────────────────────
.php-cs-fixer.cache
.phpunit.result.cache

# ── Temp files ───────────────────────────────────────────
*.bak
*.tmp

# ── WordPress (server-managed, not in repo) ──────────────
wp-content/backup-db/
wp-content/backups/
wp-content/cache/
wp-content/debug.log
wp-content/mu-plugins/
!wp-content/mu-plugins/php-aegis-loader.php
wp-content/plugins/
wp-content/upgrade/
wp-content/uploads/

# ── Miscellaneous ────────────────────────────────────────
ai-cli-crash-capture/
sync_report*.txt


# OS & Editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/


# Build
/target/
/_build/
/build/
/dist/
/out/
/zig-out/
/zig-cache/


# Dependencies
/node_modules/
/vendor/
/deps/
/.elixir_ls/


# Rust

# Cargo.lock  # Keep for binaries


# Elixir
/cover/
/doc/
*.ez
erl_crash.dump


# Julia
*.jl.cov
*.jl.mem
/Manifest.toml


# ReScript
/lib/bs/
/.bsb.lock


# Python (SaltStack only)
__pycache__/
*.py[cod]
.venv/


# Ada/SPARK
*.ali
/obj/
/bin/


# Haskell
/.stack-work/
/dist-newstyle/


# Chapel
*.chpl.tmp.*


# Secrets (see earlier SOPS+age section for canonical rules)
.env
.env.*
!.env.example
!.env.example.production
*.pem
*.key


# Test/Coverage
/coverage/
htmlcov/


# Logs
*.log
/logs/


# Machine-readable locks
.machine_readable/.locks/


# Temp
/tmp/
*.tmp
*.bak