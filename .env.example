# SPDX-License-Identifier: PMPL-1.0-or-later
# Environment variables for NUJ LCB website
# Copy local stack values to .env.
# Keep publish and deployment secrets in local-only .env.local or CI secrets.

# Database
WORDPRESS_DB_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=change_me_in_production
DB_NAME=wordpress
DB_USER=wordpress
TABLE_PREFIX=wp_
WP_DEBUG=false

# OAuth2 (for Svalinn Compose)
OAUTH2_ISSUER=https://auth.example.com
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# Vörðr Runtime
VORDR_AUTH_TOKEN=change_me_in_production

# WordPress
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=
SINOPLE_CAPABILITY_SECRET=
SINOPLE_CAPABILITY_MODE=enforce

# Generate WordPress salts: https://api.wordpress.org/secret-key/1.1/salt/

# IPFS publish / Cloudflare DNSLink
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=
IPFS_HOST=ipfs.nuj-lcb.org.uk
PINATA_GATEWAY_DOMAIN=
CLOUDFLARE_WEB3_GATEWAY=false
CLOUDFLARE_WEB3_HOSTNAME_ID=
CLOUDFLARE_WEB3_HOSTNAME_NAME=ipfs.nuj-lcb.org.uk

# Monitoring and optional Hypatia workflow dispatch
# CF_* may reuse the same values as CLOUDFLARE_* if desired.
CF_API_TOKEN=
CF_ZONE_ID=
OLS_STATUS_USER=
OLS_STATUS_PASS=
GITHUB_TOKEN=
GITHUB_REPOSITORY=hyperpolymath/lcb-website
GITHUB_REF_NAME=main
HYPATIA_WORKFLOW_FILE=hypatia-scan.yml
