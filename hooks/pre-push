#!/bin/bash
# SPDX-License-Identifier: PMPL-1.0-or-later
# Pre-push hook

echo "Running pre-push checks..."

# Check for large files
echo "Checking for large files..."
large_files=$(find . -type f -size +10M -not -path "./.git/*" -not -path "./node_modules/*" 2>/dev/null)
if [ -n "$large_files" ]; then
  echo "⚠️  Warning: Found large files (>10MB):"
  echo "$large_files"
  echo "Consider using Git LFS for large files"
  read -p "Continue with push? (y/N) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

# Check branch name
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" = "main" ] || [ "$current_branch" = "master" ]; then
  echo "Pushing to $current_branch branch"
fi

# Verify push is going to origin (GitHub) — per estate rule, origin is the
# only forge we push to directly. Mirror system propagates to others.
origin_url=$(git remote get-url origin 2>/dev/null || echo "")
if [[ "$origin_url" == *"github.com"*"hyperpolymath"*"lcb-website"* ]]; then
  echo "✓ origin points to GitHub hyperpolymath/lcb-website"
else
  echo "⚠️  origin URL looks unexpected: $origin_url"
  echo "   Expected: git@github.com:hyperpolymath/lcb-website.git"
  exit 1
fi

echo "✅ Pre-push checks passed"
exit 0
